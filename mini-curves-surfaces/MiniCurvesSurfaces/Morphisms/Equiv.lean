#eval cremonaTransform 1 2 3
#eval cremonaTransform 0 1 1
#eval nodalCubicParametrization 2
#eval cuspidalCubicParametrization 2
#eval genusAfterBlowupSingular 3 2
#eval genusAfterBlowupSingular 3 1
#eval cremonaDegreeFormula 2 1 1 1
#eval cremonaDegreeFormula 3 1 1 0

#eval "── Resolution and Cremona ──"
#eval resolutionGenus 1 1
#eval resolutionGenus 3 3
#eval nodalCurveResolvedGenus 1 1
#eval nodalCurveResolvedGenus 3 2
#eval cuspidalCurveResolvedGenus 1 1
#eval cuspidalCurveResolvedGenus 3 1
#eval areBirationallyEquivalentViaBlowups
#eval quadraticCremonaInverse 1 2 3
#eval quadraticCremonaInverse 2 3 5
#eval sarkisovProgramSurfaces
#eval cremonaGroupProperties

